                }),

                //specifications

                listener("click", ".specifications-accordion", (event) => {
                    console.log("entered in specification category");
                    const titleEl = event.target.closest(".spec-title");
                    if (!titleEl) return;

                    let spec = titleEl.innerText.trim();
                    console.log("Specification clicked:", titleEl.innerText.trim());
                    console.log("Specification clicked:", spec);


                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Specifications",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "MERU & MEADOW",
                                SpecificationsCategory: spec,
                                LeadId: leadId,
                            },
                        },
                    });
                }),

                //master plan
                (() => {
                    // Check if URL contains "meruandmeadow"
                    if (!window.location.href.toLowerCase().includes("meruandmeadow")) {
                        // console.log("=== NOT ON MERUANDMEADOW PAGE - SCRIPT DISABLED ===");

                        return;
                    }
                    console.log("=== MASTER PLAN TRACKING SCRIPT LOADED ===");

                    // console.log("=== MERUANDMEADOW PAGE DETECTED - SCRIPT ACTIVE ===");

                    setTimeout(() => {
                        const planContainer = document.querySelector(
                            "#master-plan .plan-container"
                        );

                        if (!planContainer) {
                            console.log("=== PLAN CONTAINER NOT FOUND ===");
                            return;
                        }

                        // console.log("=== PLAN CONTAINER FOUND ===");

                        planContainer.addEventListener("click", () => {
                            // console.log("=== PLAN CONTAINER CLICKED ===");

                            // Initialize tracking variables if not already set
                            if (!window.masterPlanTracking) {
                                window.masterPlanTracking = {
                                    startTime: null,
                                    totalTime: 0,
                                    isTracking: false,
                                    eventSent: false,
                                    sessionTime: 0, // Track current session separately
                                };
                                // console.log("=== INITIALIZED MASTER PLAN TRACKING ===");
                            }

                            const tracking = window.masterPlanTracking;
                            // console.log("=== CURRENT TRACKING STATE ===", tracking);

                            // Start tracking on first click (or restart after event was sent)
                            if (!tracking.isTracking && !tracking.eventSent) {
                                tracking.startTime = Date.now();
                                tracking.isTracking = true;
                                tracking.sessionTime = 0; // Reset session time
                                console.log(
                                    "Started Master Plan time tracking at",
                                    new Date().toLocaleTimeString()
                                );

                                // Function to pause tracking (when tab is hidden or user leaves section)
                                const pauseTracking = (reason) => {
                                    if (tracking.isTracking && tracking.startTime) {
                                        const timeSpent = Math.round(
                                            (Date.now() - tracking.startTime) / 1000
                                        );
                                        tracking.sessionTime = timeSpent;
                                        tracking.isTracking = false;
                                        console.log(
                                            `Paused tracking (${reason}). Session: ${timeSpent}s`
                                        );
                                    }
                                };

                                // Function to resume tracking (when tab becomes visible again)
                                const resumeTracking = () => {
                                    const masterPlanSection =
                                        document.querySelector("#master-plan");
                                    if (!masterPlanSection) return;

                                    const rect = masterPlanSection.getBoundingClientRect();
                                    const isVisible =
                                        rect.top < window.innerHeight && rect.bottom > 0;

                                    if (
                                        isVisible &&
                                        !tracking.isTracking &&
                                        !tracking.eventSent
                                    ) {
                                        tracking.startTime = Date.now();
                                        tracking.isTracking = true;
                                        console.log(
                                            "Resumed Master Plan tracking at",
                                            new Date().toLocaleTimeString()
                                        );
                                    }
                                };

                                // Function to send the final event
                                const sendMasterPlanEvent = (reason) => {
                                    // Calculate final time if still tracking
                                    if (tracking.isTracking && tracking.startTime) {
                                        const timeSpent = Math.round(
                                            (Date.now() - tracking.startTime) / 1000
                                        );
                                        tracking.sessionTime = timeSpent;
                                        tracking.isTracking = false;
                                    }

                                    // Send event only once per session
                                    if (tracking.sessionTime > 0 && !tracking.eventSent) {
                                        tracking.eventSent = true;
                                        console.log(
                                            `Sending Master Plan event (${reason}): ${tracking.sessionTime} seconds`
                                        );


                                        SalesforceInteractions.sendEvent({
                                            interaction: {
                                                name: "Master Plan",
                                                eventType: "assetzEvents",
                                                attribute: {
                                                    ProjectName: "MERU & MEADOW",
                                                    TimeInSeconds: tracking.sessionTime,
                                                    LeadId: leadId,
                                                },
                                            },
                                        });

                                        // console.log("=== EVENTS SENT SUCCESSFULLY ===");

                                        // Cleanup listeners
                                        window.removeEventListener("scroll", checkIfLeftSection);
                                        document.removeEventListener(
                                            "visibilitychange",
                                            handleVisibilityChange
                                        );
                                        window.removeEventListener("beforeunload", sendOnUnload);

                                        // Reset for next session
                                        setTimeout(() => {
                                            tracking.eventSent = false;
                                            tracking.sessionTime = 0;
                                            // console.log("=== READY FOR NEXT SESSION ===");
                                        }, 1000); // Reset after 1 second
                                    }
                                };

                                // Monitor when user scrolls away from the section
                                const checkIfLeftSection = () => {
                                    const masterPlanSection =
                                        document.querySelector("#master-plan");
                                    if (!masterPlanSection) return;

                                    const rect = masterPlanSection.getBoundingClientRect();
                                    const isVisible =
                                        rect.top < window.innerHeight && rect.bottom > 0;

                                    if (!isVisible && tracking.isTracking) {
                                        // console.log("=== USER SCROLLED AWAY FROM MASTER PLAN ===");
                                        sendMasterPlanEvent("scrolled away");
                                    }
                                };

                                // Handle tab visibility changes (switching tabs, minimizing browser, etc.)
                                const handleVisibilityChange = () => {
                                    if (document.hidden) {
                                        pauseTracking("tab hidden");
                                    } else {
                                        resumeTracking();
                                    }
                                };

                                // Attach scroll listener to detect when user leaves
                                window.addEventListener("scroll", checkIfLeftSection);
                                // console.log("=== ATTACHED SCROLL LISTENER ===");

                                // Attach visibility change listener for tab switching
                                document.addEventListener(
                                    "visibilitychange",
                                    handleVisibilityChange
                                );
                                // console.log("=== ATTACHED VISIBILITY CHANGE LISTENER ===");

                                // Send on page unload
                                const sendOnUnload = () => {
                                    sendMasterPlanEvent("page unload");
                                };

                                window.addEventListener("beforeunload", sendOnUnload);
                                // console.log("=== ATTACHED BEFOREUNLOAD LISTENER ===");
                            } else if (tracking.eventSent) {
                                // console.log("=== PREVIOUS SESSION COMPLETED - WAITING FOR RESET ===");
                            } else {
                                // console.log("=== TRACKING ALREADY ACTIVE ===");
                            }
                        });
                    }, 3000);
                })(),

                //Virtual Tour

                (() => {
                    const iframe = document.querySelector(".iframe-element");
                    const section = document.querySelector(".virtual-tour-section");

                    if (!iframe || !section) return;

                    console.log("Virtual Tour tracking initialized");

                    let sessionActive = false;
                    let startTime = 0;
                    let lastScrollY = window.scrollY;
                    let sectionTop = 0;
                    let sectionBottom = 0;
                    let sessionCount = 0; // MULTI SESSION COUNTER

                    // Start session after iframe click
                    window.addEventListener("blur", () => {
                        if (document.activeElement !== iframe) return;
                        if (sessionActive) return;

                        const rect = section.getBoundingClientRect();
                        const scrollY = window.scrollY;

                        sectionTop = rect.top + scrollY;
                        sectionBottom = rect.bottom + scrollY;

                        sessionActive = true;
                        startTime = Date.now();
                        lastScrollY = scrollY;
                        sessionCount++;

                        console.log(`Virtual Tour session ${sessionCount} started`);

                        window.addEventListener("scroll", onScroll, { passive: true });
                        section.addEventListener("mouseleave", onMouseLeave); // desktop
                        window.addEventListener("beforeunload", fireEvent);
                    });

                    //Scroll UP logic
                    function onScroll() {
                        if (!sessionActive) return;

                        const currentScrollY = window.scrollY;
                        const scrollingUp = currentScrollY < lastScrollY;
                        lastScrollY = currentScrollY;

                        const viewportTop = currentScrollY;
                        const viewportBottom = viewportTop + window.innerHeight;

                        //Scroll UP → EXIT
                        if (scrollingUp && viewportBottom < sectionTop) {
                            console.log(`Scroll UP → left section (session ${sessionCount})`);
                            fireEvent("scroll_up");
                            return;
                        }

                        // Mobile fallback → Scroll DOWN exit
                        if (!scrollingUp && viewportTop > sectionBottom) {
                            console.log(`Scroll DOWN → left section (session ${sessionCount})`);
                            fireEvent("scroll_down");
                        }
                    }

                    //Desktop scroll down → mouse leaves section
                    function onMouseLeave() {
                        if (!sessionActive) return;

                        console.log(`Mouse left section (session ${sessionCount})`);
                        fireEvent("mouse_leave");
                    }

                    //Fire analytics event
                    function fireEvent(reason) {
                        if (!sessionActive) return;

                        const timeSpent = Math.round(
                            (Date.now() - startTime) / 1000
                        );

                        sessionActive = false;

                        console.log(
                            `Virtual Tour session ${sessionCount} fired → ${timeSpent}s (${reason})`
                        );

                        if (timeSpent > 0) {
                            SalesforceInteractions.sendEvent({
                                interaction: {
                                    name: "Virtual Tour",
                                    eventType: "assetzEvents",
                                    attribute: {
                                        ProjectName: "MERU & MEADOW",
                                        TimeInSeconds: timeSpent,
                                        LeadId: leadId
                                    },
                                },
                            });
                        }

                        cleanup();
                    }

                    function cleanup() {
                        window.removeEventListener("scroll", onScroll);
                        section.removeEventListener("mouseleave", onMouseLeave);
                        window.removeEventListener("beforeunload", fireEvent);

                        //Ready for next session
                        startTime = 0;
                        sectionTop = 0;
                        sectionBottom = 0;

                        console.log("Session cleaned up, ready for next session");
                    }
                })(),
            ],
        };

