      } catch (e) {
        console.error("[Salesforce personalization] Error initializing module: personalization", e);
      }
      })();
      (function () {
      // ----- module custom_parameters
      try {
        
        const config = {"keys":["leadid","assetzid","source_campaign"]};
      } catch (e) {
        console.error("[Salesforce custom_parameters] Error initializing module: custom_parameters", e);
      }
      })();

// SITEMAP AND INIT
try {
  (function () {
    document.addEventListener("DOMContentLoaded", function (event) {
    SalesforceInteractions.init({
        cookieDomain: ".assetzproperty.com",
        consents: new Promise((resolve) => {
            resolve([
                {
                    provider: "Assetz Provider",
                    purpose: SalesforceInteractions.ConsentPurpose.Tracking,
                    status: SalesforceInteractions.ConsentStatus.OptIn,
                },
            ]);
        }),
    }).then(() => {
        //console.log("Salesforce Interactions WebSDk is ready");
        SalesforceInteractions.setLoggingLevel("0");

        const {
            cashDom,
            listener,
            resolvers,
            sendEvent,
            util,
            CatalogObjectInteractionName,
        } = SalesforceInteractions;

        let leadId = null;

        if (window.location.href.includes("leadid")) {
            // console.log("user has leadId");

            const params = new URLSearchParams(window.location.search);
            leadId = params.get("leadid");

            //  console.debug("printing leadId");
            //  console.debug(leadId);

            SalesforceInteractions.sendEvent({
                interaction: { name: "LeadId capture" },

                user: {
                    attributes: {
                        LeadId: leadId,
                        eventType: "identity",
                        isAnonymous: 0,
                    },
                },
            });
        }
        const global = {
            listeners: [
                //Enquiry Form
                listener("submit", "#homeenquiry", (event) => {
                    const formData = new FormData(document.getElementById("homeenquiry"));

                    const name = document.getElementById("name").value;
                    const email = document.getElementById("email").value;
                    const phone = document.getElementById("phone").value;
                    const project = document.getElementById("comment").value;
                    const enquiryType = document.getElementById("type").value;
                    const Consent = document.getElementById("agreeform").checked;

                    if (name && emailmail && phone && project) {
                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Enquire Now",
                                eventType: "assetzEvents",
                                attribute: {
                                    FormType: enquiryType,
                                    ProjectName: project,
                                    LeadId: leadId,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Enquiry Form Identity" },
                            user: {
                                attributes: {
                                    firstName: name,
                                    phoneNumber: phone,
                                    email: email,
                                    eventType: "identity",
                                    isAnonymous: 0,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Enquiry Form Identity" },
                            user: {
                                attributes: {
                                    email: email,
                                    eventType: "contactPointEmail",
                                    isAnonymous: 0,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Enquiry Form Identity" },
                            user: {
                                attributes: {
                                    phoneNumber: phone,
                                    eventType: "contactPointPhone",
                                    isAnonymous: 0,
                                },
                            },
                        });
                    }
                }),

                //New launches(projects)

                listener("click", ".sliderimage", (event) => {
                    let element = event.target;
                    let card = null;

                    while (element && element !== document) {
                        if (
                            element.classList &&
                            element.classList.contains("projectsliderlink")
                        ) {
                            card = element;
                            break;
                        }
                        element = element.parentNode;
                    }

                    if (!card) return;

                    const name =
                        card.querySelector(".ProjectSliderText")?.innerText.trim() || "";
                    const location =
                        card.querySelector(".ProjectSliderTexttow")?.innerText.trim() || "";

                    //   console.log("Clicked Project Name:", name);
                    //   console.log("Clicked Project Location:", location);

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "New Launches",
                            eventType: "assetzEvents",
                            attribute: {
                                Location: location,
                                ProjectName: name,
                                LeadId: leadId,
                            },
                        },
                    });
                }),

                // Enquiries

                listener("submit", "#contact-form", (event) => {
                    const enquiryformData = new FormData(
                        document.getElementById("contact-form")
                    );
                    const name = enquiryformData.get("name")?.trim() || "";
                    const phone = enquiryformData.get("phone")?.trim() || "";
                    const email = enquiryformData.get("email")?.trim() || "";
                    const comment = enquiryformData.get("comment")?.trim() || "";
                    const projectSelect = document.querySelector("#project");
                    const project = projectSelect?.selectedOptions[0]?.text.trim() || "";

                    //   console.log("Captured Form Data →");
                    //   console.log("Name:", name);
                    //   console.log("Phone:", phone);
                    //   console.log("Email:", email);
                    //   console.log("Project:", project);

                    if (name && phone && email && project && comment) {
                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Enquiries Form",
                                eventType: "assetzEvents",
                                attribute: {
                                    ProjectName: project,
                                    Query: comment,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Enquiries Form Identity" },
                            user: {
                                attributes: {
                                    phoneNumber: phone,
                                    eventType: "contactPointPhone",
                                    isAnonymous: 0,
                                },
                            },
                        });
                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Enquiries Form Identity" },
                            user: {
                                attributes: {
                                    email: email,
                                    eventType: "contactPointEmail",
                                    isAnonymous: 0,
                                },
                            },
                        });
                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Enquiries Form Identity" },
                            user: {
                                attributes: {
                                    firstName: name,
                                    eventType: "identity",
                                    isAnonymous: 0,
                                },
                            },
                        });
                    }
                }),

                //Hero Banner
                listener(
                    "click",
                    ".new_launchestext, .recent_launches_vidherosectionproject, .recent_launches_box",
                    (event) => {
                        const block = event.target.closest(
                            ".slick-slide.slick-current.slick-active"
                        );
                        if (!block) return;

                        const linkEl = block.querySelector("a[href]");
                        if (!linkEl) return;

                        const url = linkEl.href;

                        let projectName = url.split("/").filter(Boolean).pop() || ""; // Remove empty strings & get last part
                        projectName = projectName.replace(/\.html$|\//g, "").trim(); // Clean extension & slashes

                        // Convert to title case: melodiesoflife → Melodies Of Life
                        projectName = projectName
                            .replace(/([a-z])([A-Z])/g, "$1 $2") // camelCase → space separated
                            .replace(/([a-z])([A-Z])/g, "$1 $2") // double pass for multiple caps
                            .toLowerCase()
                            .split(" ")
                            .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
                            .join(" ");

                        // Special cases
                        if (projectName.toLowerCase().includes("zenandsato"))
                            projectName = "ZEN & SATO";

                        const details = block.querySelectorAll(".new_launchestextdetails");
                        const bhk =
                            details[0]?.querySelector("div")?.innerText.trim() || "";
                        const sqft =
                            details[1]?.querySelector("div")?.innerText.trim() || "";
                        const location =
                            details[2]?.querySelector("div")?.innerText.trim() || "";
                        const offer =
                            block.querySelector(".recent_launchestextp")?.innerText.trim() ||
                            "";

                        // console.log("RAW URL:", url);
                        // console.log("CLEANED projectName:", projectName);

                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Hero Banner",
                                eventType: "assetzEvents",
                                attribute: {
                                    Area: sqft,
                                    Typology: bhk,
                                    Location: location,
                                    ProjectName: projectName,
                                    LeadId: leadId,
                                },
                            },
                        });
                    }
                ),

                //Home

                listener("click", ".HomeSectionsTab .Tab", (event) => {
                    // Find the clicked tab
                    const tab = event.target.closest(".Tab");
                    if (!tab) return;

                    // Extract the home type text
                    const homeType = tab.querySelector("p").textContent.trim();

                    // Print the selected home type
                    //   console.log("Selected Home Type:", homeType);

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Home Types",
                            eventType: "assetzEvents",
                            attribute: {
                                HomeType: homeType,
                                LeadId: leadId,
                            },
                        },
                    });
                }),

                // Filter

                listener("click", ".filter-button", (event) => {
                    //   console.log("IM IN the filter block");

                    // Capture filter values
                    const productType = document
                        .querySelector('select[name="type"]')
                        .value.trim();
                    const location = document
                        .querySelector('select[name="city"]')
                        .value.trim();
                    const stage = document
                        .querySelector('select[name="stage"]')
                        .value.trim();
                    const budget = document
                        .querySelector('select[name="budget"]')
                        .value.trim();

                    // Unit selection logic
                    let unitSelection = "";
                    const unitPlot = document.querySelector("#unit_plot");
                    const unitVilla = document.querySelector("#unit_villa");
                    const unitType = document.querySelector("#unit_type");
                    const anyDefault = document.querySelector("#any_default");

                    if (!unitPlot.disabled) {
                        unitSelection = unitPlot.value.trim();
                    } else if (!unitVilla.disabled) {
                        unitSelection = unitVilla.value.trim();
                    } else if (!unitType.disabled) {
                        unitSelection = unitType.value.trim();
                    } else {
                        unitSelection = anyDefault.value.trim();
                    }

                    // Build attribute object with ONLY selected filters
                    let attributes = {};

                    if (productType !== "") attributes.ProductType = productType;
                    if (location !== "") attributes.Location = location;
                    if (stage !== "") attributes.Stage = stage;
                    if (unitSelection !== "") attributes.Typology = unitSelection;
                    if (budget !== "") attributes.Budget = budget;
                    if (leadId) attributes.LeadId = leadId;

                    //   console.log("Captured Filters:", attributes);

                    // If no filters selected, do not send event
                    if (Object.keys(attributes).length === 0) {
                        //  console.log("No filters selected → Event not sent");
                        return;
                    }

                    // Send only selected filter fields
                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Filter",
                            eventType: "assetzEvents",
                            // LeadId: leadId,
                            attribute: attributes,
                        },
                    });
                }),

                //projects
                listener("click", ".project_row", (event, row) => {
                    //    console.log("im in the projects block");

                    // Ensure row is the closest .project_row
                    const clickedRow = event.target.closest(".project_row");

                    const location =
                        clickedRow.querySelector(".project_logo p")?.innerText.trim() || "";
                    const bhk =
                        clickedRow
                            .querySelector(".project-location h5")
                            ?.innerText.trim() || "";
                    const price =
                        clickedRow
                            .querySelectorAll(".project-description h6")[0]
                            ?.innerText.trim() || "";
                    const sqft =
                        clickedRow
                            .querySelectorAll(".project-description h6")[1]
                            ?.innerText.trim() || "";
                    const projectName = (
                        clickedRow
                            .querySelector(".Testimonyicon img")
                            ?.getAttribute("data-caption") || ""
                    ).toUpperCase();

                    //   console.log("Project Name:", projectName);
                    //   console.log("Location:", location);
                    //   console.log("BHK:", bhk);
                    //   console.log("Price:", price);
                    //   console.log("Square Feet:", sqft);

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Projects",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: projectName,
                                Location: location,
                                Typology: bhk,
                                Budget: price,
                                Area: sqft,
                                LeadId: leadId,
                            },
                        },
                    });
                }),
            ],
        };

        const zenandsato = {
            name: "zen-and-sato",
            isMatch: () => {
                const matches = /\/zenandsato/.test(window.location.href);

                if (matches) {
                    const sessionKey = "zenAndSatoPageVisit";
                    if (!sessionStorage.getItem(sessionKey)) {
                        setTimeout(() => {
                            //   console.log(
                            //     "User entered Zen & Sato page - sending Page Visit event"
                            //   );

                            SalesforceInteractions.sendEvent({
                                interaction: {
                                    name: "Page Visit",
                                    eventType: "assetzEvents",
                                    attribute: {
                                        ProjectName: "ZEN & SATO",
                                        LeadId: leadId,
                                    },
                                },
                            });
                            SalesforceInteractions.sendEvent({
                                interaction: {
                                    name: "Page Visit",
                                    eventType: "zenAndSato",
                                    attribute: {
                                        ProjectName: "ZEN & SATO",
                                        LeadId: leadId,
                                    },
                                },
                            });
                        }, 100);

                        sessionStorage.setItem(sessionKey, "true");
                    }
                }

                return matches;
            },
            listeners: [
                //contact form
                listener("click", ".contact-form button", (event) => {
                    // console.log("Form Details:");

                    const form = document.querySelector(".contact-form");
                    const name = form.querySelector('input[name="name"]').value;
                    const email = form.querySelector('input[name="email"]').value;
                    const phone = form.querySelector('input[name="phone"]').value;
                    const message = form.querySelector('textarea[name="message"]').value;

                    //   console.log("Form Details Captured:");
                    //   console.log("Name:", name);
                    //   console.log("Email:", email);
                    //   console.log("Contact Number:", phone);
                    //   console.log("Message:", message);

                    if (name && email && phone && message) {
                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Contact Form" },
                            user: {
                                attributes: {
                                    firstName: name,
                                    eventType: "identity",
                                    isAnonymous: 0,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Contact Form" },
                            user: {
                                attributes: {
                                    email: email,
                                    eventType: "contactPointEmail",
                                    isAnonymous: 0,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Contact Form" },
                            user: {
                                attributes: {
                                    phoneNumber: phone,
                                    eventType: "contactPointPhone",
                                    isAnonymous: 0,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Download Brochure",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "ZEN & SATO",
                                LeadId: leadId,
                            },
                        },
                    });

                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Contact Form",
                                eventType: "zenAndSato",
                                attribute: {
                                    ProjectName: "ZEN & SATO",
                                    Query: message,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Contact Form",
                                eventType: "assetzEvents",
                                attribute: {
                                    ProjectName: "ZEN & SATO",
                                    Query: message,
                                    LeadId: leadId,
                                },
                            },
                        });
                    }
                }),

                //brochure download

                listener("click", ".brochure-button", (event) => {
                    // console.log("clicked the download brochure");

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Download Brochure",
                            eventType: "zenAndSato",
                            attribute: {
                                ProjectName: "ZEN & SATO",
                            },
                        },
                    });

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Download Brochure",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "ZEN & SATO",
                                LeadId: leadId,
                            },
                        },
                    });
                }),

                //walkthrough
                listener("click", ".walkthrough-play-btn", (event) => {
                    //  console.log("ready for the walkthrough");

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Walkthrough",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "ZEN & SATO",
                                LeadId: leadId,
                            },
                        },
                    });
                }),

                // Contact Form
                listener("submit", "#contactForm", (event) => {
                    //  event.preventDefault();

                    //   console.log("Contact Form Popup submitted");

                    const formData = new FormData(document.getElementById("contactForm"));
                    const name = formData.get("name")?.trim() || "";
                    const email = formData.get("email")?.trim() || "";
                    const phone = formData.get("phone")?.trim() || "";
                    const message = formData.get("message")?.trim() || "";

                    //   console.log("Name:", name);
                    //   console.log("Email:", email);
                    //   console.log("Phone:", phone);
                    //   console.log("Message:", message);

                    if (name && email && phone && message) {
                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Contact Form" },
                            user: {
                                attributes: {
                                    firstName: name,
                                    eventType: "identity",
                                    isAnonymous: 0,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Contact Form" },
                            user: {
                                attributes: {
                                    email: email,
                                    eventType: "contactPointEmail",
                                    isAnonymous: 0,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: { name: "Contact Form" },
                            user: {
                                attributes: {
                                    phoneNumber: phone,
                                    eventType: "contactPointPhone",
                                    isAnonymous: 0,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Contact Form",
                                eventType: "zenAndSato",
                                attribute: {
                                    ProjectName: "ZEN & SATO",
                                    Query: message,
                                },
                            },
                        });

                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Contact Form",
                                eventType: "assetzEvents",
                                attribute: {
                                    ProjectName: "ZEN & SATO",
                                    Query: message,
                                    LeadId: leadId,
                                },
                            },
                        });
                    }
                }),

                //Scroll Depth Tracking - Only for zenandsato page
                (() => {
                    if (!/\/zenandsato/.test(window.location.href)) {
                        return;
                    }

                    if (!window.scrollMilestones) {
                        window.scrollMilestones = new Set();
                    }

                    const trackScrollDepth = () => {
                        const scrollTop =
                            window.pageYOffset || document.documentElement.scrollTop;
                        const scrollHeight =
                            document.documentElement.scrollHeight -
                            document.documentElement.clientHeight;

                        if (scrollHeight === 0) return;

                        const scrollPercentage = (scrollTop / scrollHeight) * 100;
                        const milestones = [25, 50, 75, 100];

                        milestones.forEach((milestone) => {
                            if (
                                scrollPercentage >= milestone &&
                                !window.scrollMilestones.has(milestone)
                            ) {
                                window.scrollMilestones.add(milestone);

                                // console.log(
                                //   `Scroll Milestone Reached: ${milestone}% (actual: ${scrollPercentage.toFixed(
                                //     2
                                //   )}%)`
                                // );

                                SalesforceInteractions.sendEvent({
                                    interaction: {
                                        name: "Scroll Depth",
                                        eventType: "assetzEvents",
                                        attribute: {
                                            ProjectName: "ZEN & SATO",
                                            ScrollPercentage: milestone,
                                            LeadId: leadId,
                                        },
                                    },
                                });
                            }
                        });
                    };

                    window.addEventListener("scroll", trackScrollDepth);

                    return () => {
                        window.removeEventListener("scroll", trackScrollDepth);
                    };
                })(),

                //gallery image click

                listener("click", ".custom-carousel-slide img", (event) => {
                    const img = event.target;
                    const slide = img.closest(".custom-carousel-slide");

                    const imageAlt = img.getAttribute("alt") || "";
                    // console.log("clicked the gallery image:", imageAlt);

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Gallery Image Click",
                            eventType: "assetzEvents",
