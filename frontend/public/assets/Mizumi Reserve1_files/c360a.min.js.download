            ],
        };

        const mizumi = {
            name: "mizumireserve",
            isMatch: () => {
                const matches = /\/mizumireserve/.test(window.location.href);

                // Send page visit event only on first match in session
                if (matches) {
                    const sessionKey = "Mizumi Reserve PageVisit";
                    if (!sessionStorage.getItem(sessionKey)) {
                        // Use setTimeout to avoid blocking isMatch
                        setTimeout(() => {
                            console.log(
                                "User entered Mizumi Reserve - sending Page Visit event"
                            );

                            SalesforceInteractions.sendEvent({
                                interaction: {
                                    name: "Page Visit",
                                    eventType: "assetzEvents",
                                    attribute: {
                                        ProjectName: "MIZUMI RESERVE",
                                        LeadId: leadId,
                                    },
                                },
                            });
                            SalesforceInteractions.sendEvent({
                                interaction: {
                                    name: "Page Visit",
                                    eventType: "mizumiReserve",
                                    attribute: {
                                        ProjectName: "MIZUMI RESERVE",
                                    },
                                },
                            });
                        }, 100);

                        sessionStorage.setItem(sessionKey, "true");
                    }
                }

                return matches;
            },

            listeners: [

                //Enquire now (contact)
                listener("submit", "#contactForm", (event) => {
                    // event.preventDefault(); // Uncomment if you want to prevent default form submission

                    const form = event.target;

                    const name = form.name.value;
                    const email = form.email.value;
