                    const message = form.message.value;

                    console.log({ name, email, phone, message });

                    // Send assetzEvents event
                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Contact Form",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                Query: message,
                                LeadId: leadId, // Make sure leadId is defined in your scope
                            },
                        },
                    });

                    // Send zenAndSato eventF
                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Contact Form",
                            eventType: "mizumiReserve",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                Query: message,
                            },
                        },
                    });

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Download Brochure",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                LeadId: leadId,
                            },
                        },
                    });

                    // Send identity event
                    SalesforceInteractions.sendEvent({
                        interaction: { name: "Contact Form Identity" },
                        user: {
                            attributes: {
                                firstName: name,
                                eventType: "identity",
                                isAnonymous: 0,
                            },
                        },
                    });

                    // Send email event
                    SalesforceInteractions.sendEvent({
                        interaction: { name: "Contact Form Identity" },
                        user: {
                            attributes: {
                                email: email,
                                eventType: "contactPointEmail",
                                isAnonymous: 0,
                            },
                        },
                    });

                    // Send phone event
                    SalesforceInteractions.sendEvent({
                        interaction: { name: "Contact Form Identity" },
                        user: {
                            attributes: {
                                phoneNumber: phone,
                                eventType: "contactPointPhone",
                                isAnonymous: 0,
                            },
                        },
                    });
                }),


                //Download brochure

                listener("click", ".brochure-button", (event) => {
                    console.log("Dowload brochure button got clicked");

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Download Brochure",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                LeadId: leadId,
                            },
                        },
                    });

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Download Brochure",
                            eventType: "mizumiReserve",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                            },
                        },
                    });

                }),

                //Specifications

                listener("click", ".specs__header", (event) => {
                    console.log("specifications clicks");
                    const category = event.currentTarget.textContent.trim();

                    if (!category) return;

                    console.log("Mizumi Reserve - Specifications Clicked:", category);

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Specifications",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                SpecificationsCategory: category,
                                LeadId: leadId,
                            },
                        },
                    });
                }),


                //contact us

                listener("click", ".address", (event) => {
                    const element = event.target.closest("a");
                    if (!element) return;

                    // Debug - check what href value you're getting
                    // console.log("Element clicked:", element);
                    // console.log("HREF value:", element.href);
                    // console.log("HREF getAttribute:", element.getAttribute("href"));

                    const href = element.getAttribute("href"); // Use getAttribute instead of .href

                    if (href.startsWith("tel:")) {
                        console.log("Mizumi Reserve - Phone Clicked");

                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Phone click",
                                eventType: "assetzEvents",
                                attribute: {
                                    ProjectName: "MIZUMI RESERVE",
                                    LeadId: leadId,
                                },
                            },
                        });
                    } else if (href.startsWith("mailto:")) {
                        console.log("Mizumi Reserve - Email Clicked");

                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Email click",
                                eventType: "assetzEvents",
                                attribute: {
                                    ProjectName: "MIZUMI RESERVE",
                                    LeadId: leadId,
                                },
                            },
                        });
                    } else {
                        return;
                    }
                }),


                //Nearby Locations
                listener("click", ".accordion-item", (event) => {
                    const accordionItem = event.target.closest(".accordion-item");
                    if (!accordionItem) return;

                    const category = accordionItem.querySelector(".accordion-title .title-left span")?.textContent.trim();
                    if (!category) return;

                    console.log("Mizumi Reserve - Nearby Location Clicked:", category);

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Nearby Locations",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                LeadId: leadId,
                            },
                        },
                    });
                }),



                //floor plans 

                listener("click", ".floorplans-desktop", (event) => {
                    const tab = event.target.closest(".floor-tab");
                    const toggle = event.target.closest("#typeToggle");

                    if (!tab && !toggle) return;

                    if (!event.isTrusted) return;

                    setTimeout(() => {
                        const activeTab = document.querySelector(".floor-tab.active");
                        const bhkType = activeTab ? activeTab.getAttribute("data-tab") : "";

                        if (!bhkType) return;

                        let fullTypology = "";

                        if (bhkType === "Aesthetics") {
                            if (toggle) return; // ignore toggle clicks on Aesthetics
                            fullTypology = "Aesthetics";
                        } else {
                            const currentType = document.getElementById("flat-type")?.textContent.trim();
                            if (!currentType) return;
                            fullTypology = `${bhkType} - ${currentType}`;
                        }

                        console.log("Mizumi Reserve - Floor Plan Clicked:", fullTypology);

                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Floor plans",
                                eventType: "assetzEvents",
                                attribute: {
                                    ProjectName: "MIZUMI RESERVE",
                                    Typology: fullTypology,
                                    LeadId: leadId,
                                },
                            },
                        });
                    }, 100);
                }),


                //Walkthrough
                listener("click", ".walkthrough-video", (event) => {
                    const playButton = event.target.closest(".play-button");

                    if (!playButton) return;

                    console.log("Mizumi Reserve - Walkthrough Play Button Clicked");

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Walkthrough",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                LeadId: leadId,
                            },
                        },
                    });
                }),

                //contact form above footer

                listener("submit", "#contact", (event) => {
                    const form = event.target;

                    const name = form.querySelector('input[name="name"]').value.trim();
                    const email = form.querySelector('input[name="email"]').value.trim();
                    const phone = form.querySelector('input[name="contact"]').value.trim();
                    const query = form.querySelector('input[name="query"]').value.trim();

                    console.log({ name, email, phone, query });

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Contact Form",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                Query: query,
                                LeadId: leadId,
                            },
                        },
                    });

                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Contact Form",
                            eventType: "mizumiReserve",
                            attribute: {
                                ProjectName: "MIZUMI RESERVE",
                                Query: query,
                            },
                        },
                    });

                    SalesforceInteractions.sendEvent({
                        interaction: { name: "Contact Form Identity" },
                        user: {
                            attributes: {
                                firstName: name,
                                eventType: "identity",
                                isAnonymous: 0,
                            },
                        },
                    });

                    SalesforceInteractions.sendEvent({
                        interaction: { name: "Contact Form Identity" },
                        user: {
                            attributes: {
                                email: email,
                                eventType: "contactPointEmail",
                                isAnonymous: 0,
                            },
                        },
                    });

                    SalesforceInteractions.sendEvent({
                        interaction: { name: "Contact Form Identity" },
                        user: {
                            attributes: {
                                phoneNumber: phone,
                                eventType: "contactPointPhone",
                                isAnonymous: 0,
                            },
                        },
                    });
                }),


                //Virtual Tour
                (() => {
                    if (!window.location.href.toLowerCase().includes("mizumi")) {
                        return;
                    }

                    setTimeout(() => {
                        const section = document.querySelector(".virtual-tour");
                        if (!section) {
                            console.log("Virtual tour section not found");
                            return;
                        }

                        console.log("Mizumi Reserve Virtual Tour tracking initialized");

                        let activeListeners = {
                            scroll: null,
                            visibility: null,
                            unload: null,
                        };

                        // Function to get currently active iframe and typology
                        const getActiveIframeAndTypology = () => {
                            const activeContainer = section.querySelector(".video-container.active");
                            if (!activeContainer) return { iframe: null, typology: "" };

                            const iframe = activeContainer.querySelector("iframe");

                            // Get typology from the active tab button
                            const activeTab = section.querySelector(".tab.active");
                            const typology = activeTab ? activeTab.textContent.trim() : "";

                            return { iframe, typology };
                        };

                        window.addEventListener("blur", () => {
                            const { iframe, typology } = getActiveIframeAndTypology();

                            if (!iframe || document.activeElement !== iframe) return;

                            console.log("Mizumi Reserve - Virtual Tour iframe clicked, Typology:", typology);

                            // Initialize tracking
                            if (!window.mizumiVirtualTourTracking) {
                                window.mizumiVirtualTourTracking = {
                                    sessions: [],
                                    currentSession: null,
                                };
                            }

                            const tracking = window.mizumiVirtualTourTracking;

                            if (!tracking.currentSession) {
                                const sessionId = tracking.sessions.length + 1;

                                tracking.currentSession = {
                                    id: sessionId,
                                    startTime: Date.now(),
                                    totalTime: 0,
                                    isTracking: true,
                                    eventSent: false,
                                    typology: typology, // Store typology at session start
                                };

                                console.log(`MIZUMI Virtual Tour SESSION ${sessionId} STARTED - Typology: ${typology}`);

                                const session = tracking.currentSession;

                                // Pause tracking
                                const pauseTracking = (reason) => {
                                    if (session.isTracking && session.startTime) {
                                        const timeSpent = Math.round(
                                            (Date.now() - session.startTime) / 1000
                                        );
                                        session.totalTime += timeSpent;
                                        session.isTracking = false;
                                        console.log(`SESSION ${session.id} Paused (${reason}). Total: ${session.totalTime}s`);
                                    }
                                };

                                // Resume tracking
                                const resumeTracking = () => {
                                    const rect = section.getBoundingClientRect();
                                    const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
                                    if (isVisible && !session.isTracking && !session.eventSent) {
                                        session.startTime = Date.now();
                                        session.isTracking = true;
                                        console.log(`SESSION ${session.id} Resumed`);
                                    }
                                };

                                // Send event
                                const sendVirtualTourEvent = (reason) => {
                                    if (session.isTracking && session.startTime) {
                                        const timeSpent = Math.round(
                                            (Date.now() - session.startTime) / 1000
                                        );
                                        session.totalTime += timeSpent;
                                        session.isTracking = false;
                                    }

                                    if (session.totalTime > 0 && !session.eventSent) {
                                        session.eventSent = true;

                                        console.log(`MIZUMI SESSION ${session.id} END (${reason}): ${session.totalTime}s - Typology: ${session.typology}`);

                                        SalesforceInteractions.sendEvent({
                                            interaction: {
                                                name: "Virtual Tour",
                                                eventType: "assetzEvents",
                                                attribute: {
                                                    ProjectName: "MIZUMI RESERVE",
                                                    Typology: session.typology,
                                                    TimeInSeconds: session.totalTime,
                                                    LeadId: leadId,
                                                },
                                            },
                                        });

                                        tracking.sessions.push(session);
                                        tracking.currentSession = null;

                                        // Cleanup listeners
                                        if (activeListeners.scroll) {
                                            window.removeEventListener("scroll", activeListeners.scroll);
                                            activeListeners.scroll = null;
                                        }
                                        if (activeListeners.visibility) {
                                            document.removeEventListener("visibilitychange", activeListeners.visibility);
                                            activeListeners.visibility = null;
                                        }
                                        if (activeListeners.unload) {
                                            window.removeEventListener("beforeunload", activeListeners.unload);
                                            activeListeners.unload = null;
                                        }

                                        console.log(`SESSION ${session.id} listeners cleaned up`);
                                    }
                                };

                                // Check if left section
                                const checkIfLeftSection = () => {
                                    const rect = section.getBoundingClientRect();
                                    const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
                                    if (!isVisible && session.isTracking) {
                                        sendVirtualTourEvent("scrolled away");
                                    }
                                };

                                // Handle visibility change
                                const handleVisibilityChange = () => {
                                    if (document.hidden) {
                                        pauseTracking("tab hidden");
                                    } else {
                                        resumeTracking();
                                    }
                                };

                                const sendOnUnload = () => {
                                    sendVirtualTourEvent("page unload");
                                };

                                activeListeners.scroll = checkIfLeftSection;
                                activeListeners.visibility = handleVisibilityChange;
                                activeListeners.unload = sendOnUnload;

                                window.addEventListener("scroll", activeListeners.scroll);
                                document.addEventListener("visibilitychange", activeListeners.visibility);
                                window.addEventListener("beforeunload", activeListeners.unload);

                                console.log(`SESSION ${sessionId} listeners attached`);

                            } else {
                                console.log("Session already in progress, click ignored");
                            }
                        });

                    }, 2000);
                })(),


                //Master plan
                (() => {
                    if (!window.location.href.toLowerCase().includes("mizumi")) { // Update this to match your project URL
                        return;
                    }
                    setTimeout(() => {
                        const planContainer = document.querySelector(
                            "#master-plan .plan-container"
                        );
                        if (!planContainer) {
                            return;
                        }
                        let activeListeners = {
                            scroll: null,
                            visibility: null,
                            unload: null,
                        };
                        planContainer.addEventListener("click", () => {
                            if (!window.mizumiMasterPlanTracking) {
                                window.mizumiMasterPlanTracking = {
                                    startTime: null,
                                    totalTime: 0,
                                    isTracking: false,
                                    eventSent: false,
                                    sessionTime: 0,
                                };
                            }
                            const tracking = window.mizumiMasterPlanTracking;
                            if (!tracking.isTracking && !tracking.eventSent) {
                                tracking.startTime = Date.now();
                                tracking.isTracking = true;
                                tracking.sessionTime = 0;

                                const pauseTracking = (reason) => {
                                    if (tracking.isTracking && tracking.startTime) {
                                        const timeSpent = Math.round(
                                            (Date.now() - tracking.startTime) / 1000
                                        );
                                        tracking.sessionTime = timeSpent;
                                        tracking.isTracking = false;
                                    }
                                };

                                const resumeTracking = () => {
                                    const masterPlanSection =
                                        document.querySelector("#master-plan");
                                    if (!masterPlanSection) return;
                                    const rect = masterPlanSection.getBoundingClientRect();
                                    const isVisible =
                                        rect.top < window.innerHeight && rect.bottom > 0;
                                    if (
                                        isVisible &&
                                        !tracking.isTracking &&
                                        !tracking.eventSent
                                    ) {
                                        tracking.startTime = Date.now();
                                        tracking.isTracking = true;
                                    }
                                };

                                const sendMasterPlanEvent = (reason) => {
                                    if (tracking.isTracking && tracking.startTime) {
                                        const timeSpent = Math.round(
                                            (Date.now() - tracking.startTime) / 1000
                                        );
                                        tracking.sessionTime = timeSpent;
                                        tracking.isTracking = false;
                                    }
                                    if (tracking.sessionTime > 0 && !tracking.eventSent) {
                                        tracking.eventSent = true;

                                        SalesforceInteractions.sendEvent({
                                            interaction: {
                                                name: "Master Plan",
                                                eventType: "assetzEvents",
                                                attribute: {
                                                    ProjectName: "MIZUMI RESERVE", // Update project name
                                                    TimeInSeconds: tracking.sessionTime,
                                                    LeadId: leadId,
                                                },
                                            },
                                        });

                                        if (activeListeners.scroll) {
                                            window.removeEventListener(
                                                "scroll",
                                                activeListeners.scroll
                                            );
                                            activeListeners.scroll = null;
                                        }
                                        if (activeListeners.visibility) {
                                            document.removeEventListener(
                                                "visibilitychange",
                                                activeListeners.visibility
                                            );
                                            activeListeners.visibility = null;
                                        }
                                        if (activeListeners.unload) {
                                            window.removeEventListener(
                                                "beforeunload",
                                                activeListeners.unload
                                            );
                                            activeListeners.unload = null;
                                        }
                                        setTimeout(() => {
                                            tracking.eventSent = false;
                                            tracking.sessionTime = 0;
                                        }, 1000);
                                    }
                                };

                                const checkIfLeftSection = () => {
                                    const masterPlanSection =
                                        document.querySelector("#master-plan");
                                    if (!masterPlanSection) return;
                                    const rect = masterPlanSection.getBoundingClientRect();
                                    const isVisible =
                                        rect.top < window.innerHeight && rect.bottom > 0;
                                    if (!isVisible && tracking.isTracking) {
                                        sendMasterPlanEvent("scrolled away");
                                    }
                                };

                                const handleVisibilityChange = () => {
                                    if (document.hidden) {
                                        pauseTracking("tab hidden");
                                    } else {
                                        resumeTracking();
                                    }
                                };

                                const sendOnUnload = () => {
                                    sendMasterPlanEvent("page unload");
                                };

                                activeListeners.scroll = checkIfLeftSection;
                                activeListeners.visibility = handleVisibilityChange;
                                activeListeners.unload = sendOnUnload;

                                window.addEventListener("scroll", activeListeners.scroll);
                                document.addEventListener(
                                    "visibilitychange",
                                    activeListeners.visibility
                                );
                                window.addEventListener("beforeunload", activeListeners.unload);
                            }
                        });
                    }, 3000);
                })(),

            ],


        };

        const pageTypeDefault = {
            name: "default",
        };

        SalesforceInteractions.initSitemap({
            global,
            pageTypeDefault,
            pageTypes: [zenandsato, meruandmeadow, Eighteenandoak, bloomanddell, banyan, mizumi],
        });
    });
});
  })()
} catch (e) {
  console.error("[Salesforce Data Cloud] Error loading sitemap:", e);
}
