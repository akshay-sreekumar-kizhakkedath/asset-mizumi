                    const typeLabel = tab.textContent.trim();
                    const fullTypology = bhkType + typeLabel;

                    console.log("Bloom & Dell - Floor Plan Type Clicked:", fullTypology);



                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Floor plans",
