                                    LeadId: leadId,
                                },
                            },
                        });

                        console.log("Phone number clicked:", phoneNumber);
                    }

                    // Email click
                    if (href.startsWith("mailto:")) {
                        const emailAddress = href.replace("mailto:", "").trim();


                        SalesforceInteractions.sendEvent({
                            interaction: {
                                name: "Email click",
                                eventType: "assetzEvents",
                                attribute: {
                                    ProjectName: "BLOOM & DELL",
                                    LeadId: leadId,
                                },
                            },
                        });

                        console.log("Email clicked:", emailAddress);
                    }
                }),

                // Specifications tabs
                listener("click", ".w3-bar.w3-black button", (event) => {
                    const button = event.target.closest("button");
                    if (!button) return;

                    // Verify it has the required classes
                    if (
                        !button.classList.contains("w3-bar-item") ||
                        !button.classList.contains("w3-button")
                    )
                        return;

                    const category = button.textContent.trim();

                    console.log(
                        "Bloom & Dell - Specification Category Clicked:",
                        category
                    );



                    SalesforceInteractions.sendEvent({
                        interaction: {
                            name: "Specifications",
                            eventType: "assetzEvents",
                            attribute: {
                                ProjectName: "BLOOM & DELL",
                                SpecificationsCategory: category,
                                LeadId: leadId,
                            },
                        },
                    });
                }),

                //Master plan

                (function () {
                    // Run only for bloomanddell
                    if (!window.location.href.includes("bloomanddell")) return;

                    // Target the specific master plan section
                    const masterPlanSection = document.querySelector(
                        ".elementor-element-4926849"
                    );

                    if (!masterPlanSection) {
                        console.log("Master plan section not found");
                        return;
                    }

                    // Find the parent section for observing when user leaves
                    const entireSection = document.querySelector(
                        ".elementor-element-17b42ae"
                    );
                    if (!entireSection) {
                        console.log("Parent section not found");
                        return;
                    }

                    let enterTime = null;
                    let hasClickedInside = false;
                    let wasInView = false;
                    let leaveTimeout = null;

                    // Function to start timer
                    const startTimer = () => {
                        if (!hasClickedInside) {
                            hasClickedInside = true;
                            enterTime = Date.now();
                            console.log("Master Plan clicked — timer started");
                        }
                    };

                    // Listen for clicks ANYWHERE in the master plan section
                    masterPlanSection.addEventListener("click", (event) => {
                        startTimer();
                        console.log("Click detected in master plan area");
                    });

                    //  Function to send event
                    const sendMasterPlanEvent = () => {
                        if (hasClickedInside && enterTime) {
                            const exitTime = Date.now();
                            const timeSpentSeconds = Math.round(
                                (exitTime - enterTime) / 1000
                            );

                            console.log("Left Master Plan area");
                            console.log("Time spent (sec):", timeSpentSeconds);

                            // Salesforce Events
                            SalesforceInteractions.sendEvent({
                                interaction: {
                                    name: "Master Plan",
                                    eventType: "assetzEvents",
                                    attribute: {
                                        ProjectName: "BLOOM & DELL",
                                        TimeInSeconds: timeSpentSeconds,
                                        LeadId: leadId,
                                    },
                                },
                            });


                            // Reset for next visit
                            enterTime = null;
                            hasClickedInside = false;
                        }
                    };

                    // Observe when user LEAVES the ENTIRE section (with delay)
                    const observer = new IntersectionObserver(
                        (entries) => {
                            entries.forEach((entry) => {
                                const isInView = entry.isIntersecting;

                                // Clear any pending timeout
                                if (leaveTimeout) {
                                    clearTimeout(leaveTimeout);
                                    leaveTimeout = null;
                                }

                                // User leaves entire section AFTER clicking
                                if (wasInView && !isInView && hasClickedInside && enterTime) {
                                    console.log(
                                        "User scrolling away from section, starting delay..."
                                    );

                                    // Wait 2 seconds before firing event
                                    leaveTimeout = setTimeout(() => {
                                        sendMasterPlanEvent();
                                    }, 1000);
                                } else if (!wasInView && isInView && hasClickedInside) {
                                    // User came back before timeout - cancel event
                                    console.log("User returned to section, canceling event");
                                }

                                // Update visibility state
                                wasInView = isInView;
                            });
                        },
                        {
                            threshold: 0.1,
                        }
                    );

                    // Observe the ENTIRE section
                    observer.observe(entireSection);
                })(),

                //Virtual Tour

                (() => {
                    // Check if URL contains "bloomanddell"
                    if (!window.location.href.toLowerCase().includes("bloomanddell")) {
                        return;
                    }

                    // Wait for iframe to load
                    setTimeout(() => {
                        const iframe = document.querySelector(
                            ".elementor-element-826d71b iframe"
                        );
                        const section = document.querySelector(
                            ".elementor-element-35be759"
                        );

                        if (!iframe || !section) {
                            console.log("Virtual tour iframe or section not found");
                            return;
                        }

                        console.log("Bloom & Dell Virtual Tour tracking initialized");

                        // Store active listeners globally
                        let activeListeners = {
                            scroll: null,
                            visibility: null,
                            unload: null,
                        };

                        // User clicks into virtual tour iframe - START TRACKING
                        window.addEventListener("blur", () => {
                            if (document.activeElement === iframe) {
                                console.log("Bloom & Dell Virtual Tour iframe clicked");

                                // Initialize tracking variables if not already set
                                if (!window.bloomVirtualTourTracking) {
                                    window.bloomVirtualTourTracking = {
                                        sessions: [],
                                        currentSession: null,
                                    };
                                }

                                const tracking = window.bloomVirtualTourTracking;

                                // Start NEW tracking session on each click (only if no active session)
                                if (!tracking.currentSession) {
                                    const sessionId = tracking.sessions.length + 1;

                                    tracking.currentSession = {
                                        id: sessionId,
                                        startTime: Date.now(),
                                        totalTime: 0,
                                        isTracking: true,
                                        eventSent: false,
                                    };

                                    console.log(
                                        `BLOOM & DELL VIRTUAL TOUR SESSION ${sessionId} STARTED at`,
                                        new Date().toLocaleTimeString()
                                    );

                                    const session = tracking.currentSession;

                                    // Function to pause tracking
                                    const pauseTracking = (reason) => {
                                        if (session.isTracking && session.startTime) {
                                            const timeSpent = Math.round(
                                                (Date.now() - session.startTime) / 1000
                                            );
                                            session.totalTime += timeSpent;
                                            session.isTracking = false;
                                            console.log(
                                                `SESSION ${session.id} Paused (${reason}). Session: ${timeSpent}s. Total: ${session.totalTime}s`
                                            );
                                        }
                                    };

                                    // Function to resume tracking
                                    const resumeTracking = () => {
                                        const rect = section.getBoundingClientRect();
                                        const isVisible =
                                            rect.top < window.innerHeight && rect.bottom > 0;

                                        if (
                                            isVisible &&
                                            !session.isTracking &&
                                            !session.eventSent
                                        ) {
                                            session.startTime = Date.now();
                                            session.isTracking = true;
                                            console.log(
                                                `SESSION ${session.id} Resumed at`,
                                                new Date().toLocaleTimeString()
                                            );
                                        }
                                    };

                                    // Function to send the final event
                                    const sendVirtualTourEvent = (reason) => {
                                        // Pause tracking first if still active
                                        if (session.isTracking && session.startTime) {
                                            const timeSpent = Math.round(
                                                (Date.now() - session.startTime) / 1000
                                            );
                                            session.totalTime += timeSpent;
                                            session.isTracking = false;
                                        }

                                        // Send event only once per session
                                        if (session.totalTime > 0 && !session.eventSent) {
                                            session.eventSent = true;

                                            console.log(
                                                `BLOOM & DELL SESSION ${session.id} END (${reason}): ${session.totalTime} seconds`
                                            );



                                            SalesforceInteractions.sendEvent({
                                                interaction: {
                                                    name: "Virtual Tour",
                                                    eventType: "assetzEvents",
                                                    attribute: {
                                                        ProjectName: "BLOOM & DELL",
                                                        TimeInSeconds: session.totalTime,
                                                        LeadId: leadId,
                                                    },
                                                },
                                            });

                                            // Save completed session
                                            tracking.sessions.push(session);
                                            tracking.currentSession = null;

                                            // Cleanup listeners using stored references
                                            if (activeListeners.scroll) {
                                                window.removeEventListener(
                                                    "scroll",
                                                    activeListeners.scroll
                                                );
                                                activeListeners.scroll = null;
                                            }
                                            if (activeListeners.visibility) {
                                                document.removeEventListener(
                                                    "visibilitychange",
                                                    activeListeners.visibility
                                                );
                                                activeListeners.visibility = null;
                                            }
                                            if (activeListeners.unload) {
                                                window.removeEventListener(
                                                    "beforeunload",
                                                    activeListeners.unload
                                                );
                                                activeListeners.unload = null;
                                            }

                                            console.log(`SESSION ${session.id} listeners cleaned up`);
                                        }
                                    };

                                    // Monitor when user scrolls away from the section
                                    const checkIfLeftSection = () => {
                                        const rect = section.getBoundingClientRect();
                                        const isVisible =
                                            rect.top < window.innerHeight && rect.bottom > 0;

                                        if (!isVisible && session.isTracking) {
                                            // User scrolled away - send event
                                            sendVirtualTourEvent("scrolled away");
                                        }
                                    };

                                    // Handle tab visibility changes
                                    const handleVisibilityChange = () => {
                                        if (document.hidden) {
                                            // Tab hidden - pause tracking but don't send event yet
                                            pauseTracking("tab hidden");
                                        } else {
                                            // Tab visible again - resume tracking if still in section
                                            resumeTracking();
                                        }
                                    };

                                    // Send on page unload
                                    const sendOnUnload = () => {
                                        sendVirtualTourEvent("page unload");
                                    };

                                    // Store references and attach listeners
                                    activeListeners.scroll = checkIfLeftSection;
                                    activeListeners.visibility = handleVisibilityChange;
                                    activeListeners.unload = sendOnUnload;

                                    window.addEventListener("scroll", activeListeners.scroll);
                                    document.addEventListener(
                                        "visibilitychange",
                                        activeListeners.visibility
                                    );
                                    window.addEventListener(
                                        "beforeunload",
                                        activeListeners.unload
                                    );

                                    console.log(`SESSION ${sessionId} listeners attached`);
                                } else {
                                    console.log("Session already in progress, click ignored");
                                }
                            }
                        });
                    }, 2000);
                })(),
            ],
        };

        const banyan = {
            name: "38 & Banyan",
            isMatch: () => {
                const matches = /\/38andbanyan/.test(window.location.href);

                // Send page visit event only on first match in session
                if (matches) {
                    const sessionKey = "38 & Banyan PageVisit";
                    if (!sessionStorage.getItem(sessionKey)) {
                        // Use setTimeout to avoid blocking isMatch
                        setTimeout(() => {
                            console.log(
                                "User entered 38 & Banyan - sending Page Visit event"
                            );

                            SalesforceInteractions.sendEvent({
                                interaction: {
                                    name: "Page Visit",
                                    eventType: "assetzEvents",
                                    attribute: {
                                        ProjectName: "38 & BANYAN",
                                        LeadId: leadId,
                                    },
                                },
                            });
                            SalesforceInteractions.sendEvent({
                                interaction: {
                                    name: "Page Visit",
                                    eventType: "Banyan",
                                    attribute: {
                                        ProjectName: "38 & BANYAN",
                                        // LeadId: leadId,
                                    },
                                },
                            });
                        }, 100);

                        sessionStorage.setItem(sessionKey, "true");
                    }
                }

                return matches;
            },
            listeners: [
