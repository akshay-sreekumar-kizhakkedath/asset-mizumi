                    // Get parent elementor tab to know if it's 3BHK or 4BHK
                    const parentContent = tab.closest(".elementor-tab-content");
                    const tabId = parentContent?.getAttribute("id");

                    let bhkType = "";
                    if (tabId === "elementor-tab-content-1431") {
                        bhkType = "3BHK - ";
                    } else if (tabId === "elementor-tab-content-1432") {
                        bhkType = "4BHK - ";
