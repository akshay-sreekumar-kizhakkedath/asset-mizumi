    tab.classList.add("active");

    const key = tab.dataset.subtab;

    floorImage.classList.remove("show");
    setTimeout(() => {
      floorImage.src = aestheticsData[key].image;
      floorImage.classList.add("show");
    }, 10);

    label.textContent = aestheticsData[key].label;
    viewButton.textContent = key === "living" ? "View Bathroom" : "View Living";
    viewButton.onclick = () => switchTo(key === "living" ? "bathroom" : "living");
  });
});

}

floorTabs.forEach(tab => {
  tab.addEventListener("click", () => {
    floorTabs.forEach(t => t.classList.remove("active"));
    tab.classList.add("active");
    currentTab = tab.dataset.tab;

    if (currentTab === "Aesthetics") {
      floorDetails.style.display = "none";
      aestheticsTabs.style.display = "flex";
      floorImage.src = aestheticsData.living.image;
      label.textContent = aestheticsData.living.label;
      viewButton.style.display = "inline-block";
    } else {
      aestheticsTabs.style.display = "none";
      floorDetails.style.display = "block";
      label.textContent = "";
      viewButton.style.display = "none";
      currentTypeIndex = 0;
      updateFloorUI();
    }
  });
});

typeToggle.addEventListener("click", () => {
  currentTypeIndex = (currentTypeIndex + 1) % floorData[currentTab].types.length;
  updateFloorUI();
});

subTabs.forEach(tab => {
  tab.addEventListener("click", () => {
    subTabs.forEach(t => t.classList.remove("active"));
    tab.classList.add("active");

    const key = tab.dataset.subtab;
    floorImage.src = aestheticsData[key].image;
