const sbu = document.getElementById("sbu");
const tca = document.getElementById("tca");
const featuresList = document.getElementById("features-list");

function updateFloorUI() {
  const data = floorData[currentTab].types[currentTypeIndex];
  flatType.textContent = data.label;
  sbu.textContent = data.sbu;
  tca.textContent = data.tca;
  floorImage.src = data.image;

  featuresList.innerHTML = "";
data.features.forEach(f => {
  const li = document.createElement("li");

  const icon = document.createElement("img");
  icon.src = f.icon;
  icon.alt = f.text;
  icon.className = "feature-icon";

  const text = document.createElement("p");
  text.textContent = f.text;

  li.appendChild(icon);
  li.appendChild(text);
  featuresList.appendChild(li);
});

  if (floorData[currentTab].types.length > 1) {
    typeToggle.style.display = "inline-block";
    const nextIndex = (currentTypeIndex + 1) % floorData[currentTab].types.length;
    typeToggle.textContent = floorData[currentTab].types[nextIndex].label + " ▸";
  } else {
    typeToggle.style.display = "none";
  }
  floorImage.classList.remove("show");
setTimeout(() => {
  floorImage.src = data.image;
  floorImage.classList.add("show");
}, 10);

floorTitle.textContent = data.title;
floorDescription.textContent = data.description;
