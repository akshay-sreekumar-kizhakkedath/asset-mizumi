document.addEventListener("DOMContentLoaded", function () {
  const chSection = document.querySelector(".carbon-healing-section");

  if (!chSection) return;

  const observer = new IntersectionObserver(
    (entries, obs) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          chSection.classList.add("animate");
          obs.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.3,
    }
  );

  observer.observe(chSection);
});


// experience slider
$(document).ready(function () {
  const $textSlider = $('.experience-text-slider');
  const $slides = $('.experience-slider .slide-item');
  let currentIndex = 0;

  // Initialize text slider
  $textSlider.slick({
    slidesToShow: 1,
    slidesToScroll: 1,
    arrows: false,
    fade: true
  });

  // Update slide widths
  function setCurrent(index) {
    $slides.removeClass('wide-slide').addClass('narrow-slide');
    $($slides[index]).removeClass('narrow-slide').addClass('wide-slide');
    currentIndex = index;
    $('.current-slide').text(index + 1);
    $textSlider.slick('slickGoTo', index);
  }

  // Initial state
  setCurrent(0);

  // Hover effect
  $slides.hover(function(){
    const index = $(this).index();
    setCurrent(index);
  });

  // Arrow controls
  $('.arrow-prev').click(()=> {
    let index = (currentIndex - 1 + $slides.length) % $slides.length;
    setCurrent(index);
  });
  $('.arrow-next').click(()=> {
    let index = (currentIndex + 1) % $slides.length;
    setCurrent(index);
  });
});

// Section animation
document.addEventListener("DOMContentLoaded", function () {
  const experienceSection = document.querySelector(".experience-section");
  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if(entry.isIntersecting){
        experienceSection.classList.add("visible");
        obs.unobserve(experienceSection);
      }
    });
  }, {threshold: 0.3});
  observer.observe(experienceSection);
});

