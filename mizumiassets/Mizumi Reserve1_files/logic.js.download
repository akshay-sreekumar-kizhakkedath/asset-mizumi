// Popup logic
const enquireBtn = document.querySelector(".enquire-btn");
const popup = document.getElementById("popup");
const closeBtn = document.getElementById("closePopup");

enquireBtn.addEventListener("click", () => {
  popup.classList.add("show");
});

closeBtn.addEventListener("click", () => {
  popup.classList.remove("show");
});

popup.addEventListener("click", (e) => {
  if (e.target === popup) {
    popup.classList.remove("show");
  }
});
// highlights
// Get all image cards
const imageCards = document.querySelectorAll('.image-card');

// Store original top positions
const positions = Array.from(imageCards).map(card => {
    const rect = card.getBoundingClientRect();
    return rect.top + window.scrollY; // Get position relative to the document
});

// Apply scroll effect
window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;

    imageCards.forEach((card, index) => {
        const speed = parseFloat(card.getAttribute('data-speed')); // Ensure speed is a float
        const desiredPosition = positions[index];

        // Here, we apply a scaling factor to reduce the distance of the transformation.
        const scalingFactor = 0.5; // This value can be adjusted (between 0 and 1) to reduce the effect
        card.style.transform = `translateY(${(scrollY - desiredPosition) * speed * scalingFactor}px)`;
    });
});
// highlights mobile animation
document.addEventListener("DOMContentLoaded", () => {
  const highlightSection = document.querySelector(".highlights-mobile-section");
  const highlightCards = document.querySelectorAll(".highlight-card");

  const highlightObserver = new IntersectionObserver(
    (entries, highlightObserver) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          highlightCards.forEach((card, index) => {
            setTimeout(() => {
              card.classList.add("animate");
            }, index * 150); // stagger effect
          });
          highlightObserver.unobserve(highlightSection);
        }
      });
    },
    {
      threshold: 0.2,
    }
  );

  if (highlightSection) {
    highlightObserver.observe(highlightSection);
  }
});

// tabbed section 
(function () {
  const section = document.getElementById('township');
  if (!section) return;

  const tabsContainer = section.querySelector('.ts-tabs');
  const buttons = Array.from(tabsContainer.querySelectorAll('.ts-tab-button'));
  const indicator = tabsContainer.querySelector('.ts-tab-indicator');
  const textContent = section.querySelector('#ts-text-content');
  const images = Array.from(section.querySelectorAll('.ts-img'));

  const content = {
    township: {
      text: `
        <h2>Everything you need,<br>and more.</h2>
        <p class="p-grey">
          For the uninitiated, Mizumi Reserve might seem like yet another gated residential development. But that is just the beginning of all that it is.
        </p>
        <p class="p-grey">
          A self-sustained township. Vast open spaces intended to foster deeper community connection, equipped with over 31 indoor and outdoor amenities on par with international standards. It is a world that has been thoughtfully crafted to be an extension of your life. So you feel at home even beyond the walls of your home. 
        </p>
      `
    },
    lakes: {
      text: `
        <h2>Life by the lakeside.</h2>
        <p class="p-grey">
          There’s little that compares to the joy of living by the water.
          At Mizumi Reserve, a thoughtfully planned township, you’re surrounded by ~ 55 acres of pristine natural lakes - our greatest pride and joy. The tranquil waters, cool breeze, lush landscapes, and birdsong create a sense of peace that’s rare to find.
        </p>
        <p class="p-grey">
          We know that if there's one thing better than living close to nature, <br class="desktop-only">it's moving into it.
        </p>
      `
    }
  };

  // Entrance Animation
  section.classList.add('ts-section-hidden');
  const io = new IntersectionObserver((entries) => {
    const e = entries[0];
    if (e && e.isIntersecting) {
      section.classList.remove('ts-section-hidden');
      section.classList.add('ts-section-visible');
      io.disconnect();
    }
  }, { threshold: 0.25 });
  io.observe(section);

  function replayAnim(el) {
    if (!el) return;
    el.classList.remove('ts-mr-tab-anim');
    void el.offsetWidth;
    el.classList.add('ts-mr-tab-anim');
  }

  function moveIndicator(targetBtn) {
    if (!targetBtn || !tabsContainer || !indicator) return;
    const containerRect = tabsContainer.getBoundingClientRect();
    const btnRect = targetBtn.getBoundingClientRect();
    const left = Math.round(btnRect.left - containerRect.left);
    const width = Math.round(btnRect.width);
    indicator.style.left = `${left}px`;
    indicator.style.width = `${width}px`;
  }

  moveIndicator(tabsContainer.querySelector('.ts-tab-button.ts-active') || buttons[0]);
  window.addEventListener('resize', () => {
    moveIndicator(tabsContainer.querySelector('.ts-tab-button.ts-active') || buttons[0]);
  });

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.tab;
      if (!selected) return;

      // Buttons active state + ARIA
      buttons.forEach(b => {
        const is = (b === btn);
        b.classList.toggle('ts-active', is);
        b.setAttribute('aria-selected', is ? 'true' : 'false');
      });

      // Swap text
      if (content[selected] && content[selected].text) {
        textContent.innerHTML = content[selected].text;
      }

      // Swap images
      images.forEach(img => {
        const isActive = img.dataset.tab === selected;
        img.classList.toggle('ts-img--active', isActive);
        img.style.display = isActive ? 'block' : 'none'; // ensures only one visible
      });

      // Replay animations
      replayAnim(textContent);
      images.forEach(img => {
        if (img.dataset.tab === selected) replayAnim(img);
      });

      // Move indicator
      moveIndicator(btn);
    });
  });
})();
// masterplan
// Get all legend items and map buttons
const legendItems = document.querySelectorAll(".legend-item");
const mapButtons = document.querySelectorAll(".map-button");
const mapLabels = document.querySelectorAll(".map-label");

// Helper: Show label for a given ID
function showLabel(id) {
  mapLabels.forEach((label) => {
    label.classList.toggle("visible", label.dataset.id === id);
  });
}

// Helper: Hide all labels
function hideLabels() {
  mapLabels.forEach((label) => {
    label.classList.remove("visible");
  });
}

// Hover effect: Highlight button and show label on legend hover
legendItems.forEach((item) => {
  item.addEventListener("mouseenter", () => {
    const id = item.querySelector("span").innerText;

    // Highlight matching button
    mapButtons.forEach((btn) => {
      if (btn.dataset.id === id) {
        btn.style.backgroundColor = "#000000";
      } else {
        btn.style.backgroundColor = "";
      }
    });

    // Show matching label
    showLabel(id);
  });

  item.addEventListener("mouseleave", () => {
    mapButtons.forEach((btn) => (btn.style.backgroundColor = ""));
    hideLabels();
  });
});

// Hover effect: Highlight legend and show label on map button hover
mapButtons.forEach((btn) => {
  btn.addEventListener("mouseenter", () => {
    const id = btn.dataset.id;

    // Highlight legend item
    legendItems.forEach((item) => {
      const itemId = item.querySelector("span").innerText;
      if (itemId === id) {
        item.classList.add("active");
      }
    });

    // Show label
    showLabel(id);
  });

  btn.addEventListener("mouseleave", () => {
    legendItems.forEach((item) => item.classList.remove("active"));
    hideLabels();
  });
});

// Animate master plan section when it enters viewport
const masterPlanSection = document.querySelector(".master-plan");

if (masterPlanSection) {
  const masterPlanSectionObserver = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("animate");
        masterPlanSectionObserver.unobserve(entry.target);
      }
    },
    { threshold: 0.2 }
  );

  masterPlanSectionObserver.observe(masterPlanSection);
}


// highlights slider
$(document).ready(function () {
  // Main slider
  const $mainSlider = $('.highlight-slider');
  $mainSlider.slick({
    arrows: false,
    asNavFor: '.highlight-thumbnails',
    fade: true,
    speed: 800,
    infinite: true,
  });

  // Thumbnails (horizontal)
  const $thumbs = $('.highlight-thumbnails');
  $thumbs.slick({
    slidesToShow: 2,
    slidesToScroll: 1,
    asNavFor: '.highlight-slider',
    focusOnSelect: true,
    vertical: false,
    infinite: true,
    arrows: false,
    centerMode: false,
    variableWidth: true,
  });

  // ✅ Show next image in thumbnail relative to main slider
  $mainSlider.on('afterChange', function (event, slick, currentSlide) {
    const total = slick.slideCount;
    const nextIndex = (currentSlide + 1) % total; // next image
    $thumbs.slick('slickGoTo', nextIndex); // make thumbnail show next image
  });

  // ✅ Click thumbnail → main slider updates
  $thumbs.on('click', '.slick-slide', function (e) {
    e.preventDefault();
    const index = $(this).data('slick-index');
    if (typeof index !== 'undefined') {
      $mainSlider.slick('slickGoTo', index); // show corresponding main slide
    }
  });

  // Custom arrows
  $('.custom-arrow-horizontal.prev').click(function () {
    $thumbs.slick('slickPrev');
  });
  $('.custom-arrow-horizontal.next').click(function () {
    $thumbs.slick('slickNext');
  });

  // Progress bar logic
  $mainSlider.on('afterChange', function (event, slick, currentSlide) {
    const total = slick.slideCount;
    const progress = ((currentSlide + 1) / total) * 100;
    $('.horizontal-progress-fill').css('width', `${progress}%`);
  });

  // Initial thumbnail position to show next image
  const initialNext = ($mainSlider.slick('getSlick').currentSlide + 1) % $mainSlider.slick('getSlick').slideCount;
  $thumbs.slick('slickGoTo', initialNext);
});
// mobile version 
$(document).ready(function () {
  const $slider = $('.highlight-mobile-slider');
  const $tabs = $('.highlight-tab');
  const $indicator = $('.highlight-tab-indicator');
  const $wrapper = $('.highlight-tabs-wrapper');

  // Init slider
  $slider.slick({
    arrows: false,
    dots: false,
    adaptiveHeight: true
  });

  // Ensure indicator is placed correctly after slick sets sizes
  function moveIndicator(index) {
    const $tab = $tabs.eq(index);
    if (!$tab.length) return;
    const scrollLeft = $wrapper.scrollLeft();
    // position().left gives position relative to the .highlight-tabs element
    $indicator.css({
      left: $tab.position().left + scrollLeft + 'px',
      width: $tab.outerWidth() + 'px'
    });
  }

  // After slick initializes, set the indicator (use setTimeout for safety on slow images)
  $slider.on('init setPosition', function () {
    const activeIndex = $tabs.filter('.active').data('slide') || 0;
    moveIndicator(activeIndex);
  });

  // Slick sometimes fires init before we attach listener; call once
  setTimeout(function () {
    moveIndicator(0);
  }, 50);

  // Tab click
  $tabs.on('click', function () {
    const index = $(this).data('slide');
    $tabs.removeClass('active');
    $(this).addClass('active');

    $slider.slick('slickGoTo', index);
    $('.highlight-text-item').removeClass('active').eq(index).addClass('active');

    // Ensure indicator moves (small timeout to allow any layout changes)
    setTimeout(function () {
      moveIndicator(index);
    }, 10);
  });

  // Slider change -> update tabs + text + indicator
  $slider.on('afterChange', function (event, slick, currentSlide) {
    $tabs.removeClass('active').eq(currentSlide).addClass('active');
    $('.highlight-text-item').removeClass('active').eq(currentSlide).addClass('active');
    moveIndicator(currentSlide);
  });

  // Recalculate indicator on scroll of the tab wrapper
  $wrapper.on('scroll', function () {
    const activeIndex = $tabs.filter('.active').data('slide') || 0;
    moveIndicator(activeIndex);
  });

  // Recalculate indicator on window resize (debounced)
  let resizeTimer = null;
  $(window).on('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      const activeIndex = $tabs.filter('.active').data('slide') || 0;
      moveIndicator(activeIndex);
    }, 80);
  });

  // ===== Arrow buttons (INSIDE ready so $slider is in scope) =====
  $('.highlight-arrow.left').on('click', function () {
    $slider.slick('slickPrev');
  });

  $('.highlight-arrow.right').on('click', function () {
    $slider.slick('slickNext');
  });

});


