// location section 
document.addEventListener("DOMContentLoaded", function () {
  const section = document.querySelector(".location-connectivity");
  const tabButtons = section.querySelectorAll(".tab-btn");
  const tabContents = section.querySelectorAll(".tab-content");
  const titleH2 = section.querySelector(".section-header .title h2");

  // --- Tab Switching with Animation ---
  tabButtons.forEach(btn => {
    btn.addEventListener("click", () => {
      const tab = btn.dataset.tab;

      // Animate title
      titleH2.classList.add("fade-out");
      setTimeout(() => {
        titleH2.textContent = tab.charAt(0).toUpperCase() + tab.slice(1);
        titleH2.classList.remove("fade-out");
        titleH2.classList.add("fade-in");
        setTimeout(() => titleH2.classList.remove("fade-in"), 300);
      }, 200);

      // Animate tab content
      tabContents.forEach(content => {
        const show = content.id === tab;

        if (show) {
          content.style.display = "block";
          setTimeout(() => content.classList.add("active"), 10); // trigger fade-in
        } else {
          content.classList.remove("active"); // fade-out
          setTimeout(() => { content.style.display = "none"; }, 400);
        }
      });

      // Update tab buttons active state
      tabButtons.forEach(b => {
        b.classList.toggle("active", b === btn);
        b.setAttribute("aria-selected", b === btn ? "true" : "false");
      });
    });
  });

  // --- Accordion + Image Swap Logic ---
  const accordionItems = section.querySelectorAll(".accordion-item");
  const mapImage = document.getElementById("mapImage");

  // Open first accordion by default
  const initiallyOpen = section.querySelector(".accordion-item.active");
  if (initiallyOpen) {
    const img = initiallyOpen.getAttribute("data-image");
    if (img) mapImage.src = img;
    const content = initiallyOpen.querySelector(".accordion-content");
    if (content) content.style.maxHeight = content.scrollHeight + "px";
    const arrow = initiallyOpen.querySelector(".arrow-img");
    if (arrow) arrow.src = "public/images/specifications/upward.webp";
  }

  accordionItems.forEach(item => {
    const title = item.querySelector(".accordion-title");
    const content = item.querySelector(".accordion-content");
    const arrow = item.querySelector(".arrow-img");

    title.addEventListener("click", () => {
      // Close all others
      accordionItems.forEach(i => {
        if (i !== item) {
          i.classList.remove("active");
          const c = i.querySelector(".accordion-content");
          if (c) {
            c.style.maxHeight = "0px";
            c.style.paddingTop = "0px";
          }
          const a = i.querySelector(".arrow-img");
          if (a) a.src = "images/specifications/downward.webp";
        }
      });

      const willOpen = !item.classList.contains("active");
      item.classList.toggle("active", willOpen);

      if (willOpen) {
        if (content) {
          content.style.maxHeight = content.scrollHeight + "px";
          content.style.paddingTop = "10px";
        }
        if (arrow) arrow.src = "images/specifications/upward.webp";

        const newImage = item.getAttribute("data-image");
        if (newImage) mapImage.src = newImage;
      } else {
        if (content) {
          content.style.maxHeight = "0px";
          content.style.paddingTop = "0px";
        }
        if (arrow) arrow.src = "images/specifications/downward.webp";
      }
    });

    // Adjust open content maxHeight on resize
    window.addEventListener("resize", () => {
      if (item.classList.contains("active") && content) {
        content.style.maxHeight = content.scrollHeight + "px";
      }
    });
  });
});

// for mobile 
document.addEventListener("DOMContentLoaded", () => {
  const tabBtns = document.querySelectorAll(".lc-tab-btn");
  const tabContents = document.querySelectorAll(".lc-tab-content");
  const innerTabBtns = document.querySelectorAll(".lc-inner-tab-btn");
  const categoryLists = document.querySelectorAll(".lc-category-list");
  const innerMap = document.getElementById("lc-innerMapImage");
  const heading = document.querySelector(".lc-dynamic-heading");

  // Helper: show element with fade
  const showElement = (el) => {
    el.style.display = "block";
    setTimeout(() => el.classList.add("active"), 10);
  };

  // Helper: hide element with fade
  const hideElement = (el) => {
    el.classList.remove("active");
    setTimeout(() => el.style.display = "none", 400);
  };

  // Outer Tabs
  tabBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      const tab = btn.dataset.tab;
      heading.textContent = tab.charAt(0).toUpperCase() + tab.slice(1);

      tabBtns.forEach(b => b.classList.toggle("active", b === btn));
      tabContents.forEach(c => {
        if (c.id === tab) showElement(c);
        else hideElement(c);
      });
    });
  });

  // Inner Tabs (Location)
  innerTabBtns.forEach(btn => {
    btn.addEventListener("click", () => {
      const innerTab = btn.dataset.innerTab;
      innerTabBtns.forEach(b => b.classList.toggle("active", b === btn));

      // update map
      innerMap.src = `images/location/${innerTab}.webp`;

      // animate category lists
      categoryLists.forEach(list => {
        if (list.dataset.innerTab === innerTab) showElement(list);
        else hideElement(list);
      });
    });
  });

  // Initial setup: show first outer tab & first inner tab
  tabContents.forEach(c => c.style.display = c.classList.contains("active") ? "block" : "none");
  categoryLists.forEach(l => l.style.display = l.classList.contains("active") ? "block" : "none");
});
// gallery section 
$(document).ready(function(){

  // Main slider
  $('.gallery-main').slick({
    slidesToShow: 1,
    slidesToScroll: 1,
    arrows: false,
    fade: true,
    autoplay: true,
    autoplaySpeed: 3000,
    asNavFor: '.gallery-thumbs'
  });

  // Thumbnails
  $('.gallery-thumbs').slick({
    slidesToShow: 4,
    slidesToScroll: 1,
    asNavFor: '.gallery-main',
    vertical: true,
    focusOnSelect: true,
    arrows: false,
    centerMode: true,
    infinite: true
  });

  // Function to update current thumbnail styling on all clones
  function setCurrentThumb(index) {
    $('.gallery-thumbs .slick-slide').removeClass('slick-current');
    $('.gallery-thumbs .slick-slide[data-slick-index="'+index+'"]').addClass('slick-current');
  }

  // On main slide change
  $('.gallery-main').on('afterChange', function(event, slick, currentSlide){
    setCurrentThumb(currentSlide);
  });

  // On thumbnail click
  $('.gallery-thumbs').on('click', '.slick-slide', function(){
    var index = $(this).attr('data-slick-index');
    $('.gallery-main').slick('slickGoTo', parseInt(index));
    setCurrentThumb(parseInt(index));
  });

  // Initialize first active
  setCurrentThumb(0);

  // Force Slick to recalc sizes
  $('.gallery-main, .gallery-thumbs').slick('setPosition');
  setTimeout(function(){ $(window).trigger('resize'); }, 100);
});
