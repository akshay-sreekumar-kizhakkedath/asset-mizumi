// specification section
document.addEventListener("DOMContentLoaded", function () {
  const root = document.querySelector(".specs");
  if (!root) return;

  const items = Array.from(root.querySelectorAll(".specs__item"));

  items.forEach((item, index) => {
    const header = item.querySelector(".specs__header");
    const panel = item.querySelector(".specs__panel");

    // Accessibility IDs
    const headerId = `specs-header-${index}`;
    const panelId = `specs-panel-${index}`;
    header.id = headerId;
    panel.id = panelId;
    header.setAttribute("aria-controls", panelId);
    panel.setAttribute("aria-labelledby", headerId);
    panel.setAttribute("role", "region");

    // Set initial expanded state
    const openOnLoad = item.classList.contains("is-open");
    header.setAttribute("aria-expanded", openOnLoad ? "true" : "false");
    if (openOnLoad) {
      // Set to scrollHeight so it displays; after animation we set to 'none'
      panel.style.maxHeight = panel.scrollHeight + "px";
      panel.addEventListener("transitionend", function onInit() {
        // switch to 'none' so internal content can reflow on resize
        if (item.classList.contains("is-open")) panel.style.maxHeight = "none";
        panel.removeEventListener("transitionend", onInit);
      });
    } else {
      panel.style.maxHeight = "0px";
    }

    header.addEventListener("click", () => {
      const isOpen = item.classList.contains("is-open");

      // Close all others (single-open UX)
      items.forEach((other) => {
        if (other !== item) closeItem(other);
      });

      // Toggle clicked item
      if (isOpen) closeItem(item);
      else openItem(item);
    });

    // helper functions
    function openItem(it) {
      const hdr = it.querySelector(".specs__header");
      const pnl = it.querySelector(".specs__panel");
      it.classList.add("is-open");
      hdr.setAttribute("aria-expanded", "true");

      // Set explicit maxHeight to enable transition
      pnl.style.maxHeight = pnl.scrollHeight + "px";

      // After the transition completes, set to 'none' so panel can grow/shrink naturally if content changes
      const onEnd = function (e) {
        if (e.propertyName === "max-height") pnl.style.maxHeight = "none";
        pnl.removeEventListener("transitionend", onEnd);
      };
      pnl.addEventListener("transitionend", onEnd);
    }

    function closeItem(it) {
      const hdr = it.querySelector(".specs__header");
      const pnl = it.querySelector(".specs__panel");

      // if maxHeight is 'none' (auto), set to current scrollHeight to start the animation from a pixel value
      if (!pnl.style.maxHeight || pnl.style.maxHeight === "none") {
        pnl.style.maxHeight = pnl.scrollHeight + "px";
      }

      // force reflow to ensure transition picks up
      pnl.getBoundingClientRect();

      // animate to 0
      pnl.style.maxHeight = "0px";
      hdr.setAttribute("aria-expanded", "false");
      it.classList.remove("is-open");
    }
  });

  // OPTIONAL: update open panel heights on window resize
  let resizeTimer;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      const open = root.querySelector(".specs__item.is-open");
      if (open) {
        const pnl = open.querySelector(".specs__panel");
        // if panel is 'none' (auto) we can leave it; if it's a px value, update it
        if (pnl.style.maxHeight && pnl.style.maxHeight !== "none") {
          pnl.style.maxHeight = pnl.scrollHeight + "px";
        }
      }
    }, 120);
  });
});
