// clubhouse animation 
const clubhouseSection = document.querySelector('.clubhouse-section');

function revealClubhouseSection() {
  const rect = clubhouseSection.getBoundingClientRect();
  if (rect.top < window.innerHeight * 0.8) {
    clubhouseSection.classList.add('visible');
    window.removeEventListener('scroll', revealClubhouseSection); // trigger once
  }
}

window.addEventListener('scroll', revealClubhouseSection);
revealClubhouseSection();
