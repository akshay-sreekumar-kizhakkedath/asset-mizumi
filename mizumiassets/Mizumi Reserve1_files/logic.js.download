  }, 10);

  label.textContent = "";
  viewButton.style.display = "none";
}
    // if Aesthetics: show gallery & hide card
    if (currentTab === 'Aesthetics') {
      if (mCard) mCard.style.display = 'none';
      if (mAestheticsGallery) {
        mAestheticsGallery.style.display = 'block';
        mAestheticsGallery.innerHTML = '';
        tabData.types.forEach(t => { 
    const div = document.createElement('div'); // wrapper per item

    const p = document.createElement('p');
    p.textContent = t.label;

    const img = document.createElement('img');
    img.src = t.image;
    img.alt = t.label;

    // append text first, then image
    div.appendChild(p);
    div.appendChild(img);

    mAestheticsGallery.appendChild(div);
        });
      }
    } else {
      if (mAestheticsGallery) mAestheticsGallery.style.display = 'none';
      if (mCard) mCard.style.display = 'block';
      if (mFlatType) mFlatType.textContent = typeObj.label || '';
      if (mSbu) mSbu.textContent = typeObj.sbu || '';
      if (mTca) mTca.textContent = typeObj.tca || '';
      if (mFeatures) {
        mFeatures.innerHTML = '';
        (typeObj.features || []).forEach(f => {
          const li = document.createElement('li');
          const img = document.createElement('img');
          img.src = f.icon;
          img.alt = f.text;
          const p = document.createElement('p');
          p.textContent = f.text;
          li.appendChild(img);
          li.appendChild(p);
          mFeatures.appendChild(li);
        });
      }
    }
   if (mTypeToggle) {
  mTypeToggle.style.display = (currentTab === '4BHK' || floorData[currentTab].types.length <= 1) 
    ? 'none' 
    : 'inline-block';

  // ✅ Add this line to update button text
  const nextIndex = (currentTypeIndex + 1) % floorData[currentTab].types.length;
  mTypeToggle.textContent = floorData[currentTab].types[nextIndex].label + " ▸";
}
  }

  // move tab underline for a given tab element
  function moveMobileUnderline(tabEl) {
    if (!mIndicator || !tabEl) return;
    const parent = tabEl.parentElement;
    const parentRect = parent.getBoundingClientRect();
    const btnRect = tabEl.getBoundingClientRect();
    const left = btnRect.left - parentRect.left + parent.scrollLeft;
    mIndicator.style.left = left + 'px';
    mIndicator.style.width = btnRect.width + 'px';
  }

  // init tab event listeners (both desktop and mobile tabs share .floor-tab)
  function initTabs() {
    const tabs = document.querySelectorAll('#floorplans-full-section .floor-tab');
    tabs.forEach(tab => {
      tab.addEventListener('click', function () {
        // remove active from all
        document.querySelectorAll('#floorplans-full-section .floor-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
        currentTab = this.dataset.tab;
        currentTypeIndex = 0;
        updateUI();

        // move mobile underline when on mobile and indicator present
        if (window.innerWidth <= 768) {
          const mobileTab = document.querySelector('.floorplans-mobile-only .fp-tab[data-tab="' + currentTab + '"]') ||
                            document.querySelector('.floorplans-mobile-only .fp-tab:nth-child(1)');
          // also support mobile-class buttons with same class
          const mobileBtn = document.querySelector('.floorplans-mobile-only .fp-tab[data-tab="' + currentTab + '"]');
          if (mobileBtn) moveMobileUnderline(mobileBtn);
        } else {
          // for desktop, if there's a tab-underline element, move it
          const desktopTabsContainer = document.querySelector('.floorplans-desktop .floor-tabs');
          if (desktopTabsContainer) {
            const underline = desktopTabsContainer.querySelector('.tab-underline');
            if (underline) {
              const btn = desktopTabsContainer.querySelector('.floor-tab.active');
              if (btn) {
                underline.style.width = btn.offsetWidth + 'px';
                underline.style.left = btn.offsetLeft + 'px';
              }
            }
          }
        }
      });
    });

    // MOBILE specific tab nodes (they may be different elements)
    const mobileTabs = document.querySelectorAll('.floorplans-mobile-only .fp-tab');
    mobileTabs.forEach((btn) => {
      btn.addEventListener('click', function () {
        // remove active in mobile tabs
        document.querySelectorAll('.floorplans-mobile-only .fp-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');

        // ensure desktop tabs sync active too (shared dataset)
        document.querySelectorAll('#floorplans-full-section .floor-tab').forEach(t => {
          if (t.dataset.tab === this.dataset.tab) {
            t.classList.add('active');
          } else {
            t.classList.remove('active');
          }
        });

        currentTab = this.dataset.tab;
        currentTypeIndex = 0;
        updateUI();
        moveMobileUnderline(this);
        // ensure tab is visible (center)
        try { this.scrollIntoView({ inline: 'center', behavior: 'smooth' }); } catch(e) {}
      });
    });
  }

  // init type toggle buttons (desktop + mobile)
  function initTypeToggles() {
    const desktopToggle = document.getElementById('typeToggle');
    const mobileToggle = document.getElementById('fp-type-toggle');

    function toggleType() {
      const tabTypes = floorData[currentTab] && floorData[currentTab].types ? floorData[currentTab].types.length : 0;
      if (tabTypes <= 1) return;
      currentTypeIndex = (currentTypeIndex + 1) % tabTypes;
      
      updateUI();
    }

    if (desktopToggle) desktopToggle.addEventListener('click', toggleType);
    if (mobileToggle) mobileToggle.addEventListener('click', toggleType);
  }

  // initial setup
  function init() {
    // set default
    currentTab = '3BHK';
    currentTypeIndex = 0;

    // populate desktop initial features etc (in case)
    updateUI();

    // init listeners
    initTabs();
    initTypeToggles();

    // position indicator/underline after fonts/images likely loaded
    setTimeout(() => {
      // mobile underline initial position
      const activeMobile = document.querySelector('.floorplans-mobile-only .fp-tab.active');
      if (activeMobile) moveMobileUnderline(activeMobile);

      // desktop underline initial position
      const desktopTabsContainer = document.querySelector('.floorplans-desktop .floor-tabs');
      if (desktopTabsContainer) {
        const underline = desktopTabsContainer.querySelector('.tab-underline');
        const btn = desktopTabsContainer.querySelector('.floor-tab.active');
        if (underline && btn) {
          underline.style.width = btn.offsetWidth + 'px';
          underline.style.left = btn.offsetLeft + 'px';
        }
      }
    }, 240);

    // reposition on resize
    window.addEventListener('resize', () => {
      const activeMobile = document.querySelector('.floorplans-mobile-only .fp-tab.active');
      if (activeMobile) moveMobileUnderline(activeMobile);
      const desktopTabsContainer = document.querySelector('.floorplans-desktop .floor-tabs');
      if (desktopTabsContainer) {
        const underline = desktopTabsContainer.querySelector('.tab-underline');
        const btn = desktopTabsContainer.querySelector('.floor-tab.active');
        if (underline && btn) {
          underline.style.width = btn.offsetWidth + 'px';
          underline.style.left = btn.offsetLeft + 'px';
        }
      }
    });
  }

  // run init on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();



